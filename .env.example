# Server
PORT=3000
NODE_ENV=development

# CORS - comma separated list of allowed origins. Use * only in local development.
CORS_ORIGIN=*

# Optional: enables AI-generated natural-language narration of insights.
# If left blank, the app falls back to high-quality templated narration
# produced by the deterministic rule engine - the app is fully functional
# without this key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
